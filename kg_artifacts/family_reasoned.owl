<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/family"
         xmlns="http://example.org/family#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/family"/>

<owl:ObjectProperty rdf:about="#hasParent"/>

<owl:ObjectProperty rdf:about="#hasSibling"/>

<owl:ObjectProperty rdf:about="#hasGrandparent"/>

<owl:ObjectProperty rdf:about="#hasUncleOrAunt"/>

<owl:Class rdf:about="#Person"/>

<owl:Class rdf:about="#Man">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Woman">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Alice">
  <rdf:type rdf:resource="#Woman"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Bob">
  <rdf:type rdf:resource="#Man"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Charlie">
  <rdf:type rdf:resource="#Man"/>
  <hasParent rdf:resource="#Alice"/>
  <hasParent rdf:resource="#Bob"/>
  <hasSibling rdf:resource="#Diana"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Charlie</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Diana">
  <rdf:type rdf:resource="#Woman"/>
  <hasParent rdf:resource="#Alice"/>
  <hasParent rdf:resource="#Bob"/>
  <hasSibling rdf:resource="#Charlie"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Diana</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Eve">
  <rdf:type rdf:resource="#Woman"/>
  <hasParent rdf:resource="#Charlie"/>
  <hasGrandparent rdf:resource="#Alice"/>
  <hasGrandparent rdf:resource="#Bob"/>
  <hasUncleOrAunt rdf:resource="#Diana"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Eve</rdfs:label>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Frank">
  <rdf:type rdf:resource="#Man"/>
  <hasParent rdf:resource="#Diana"/>
  <hasGrandparent rdf:resource="#Alice"/>
  <hasGrandparent rdf:resource="#Bob"/>
  <hasUncleOrAunt rdf:resource="#Charlie"/>
  <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frank</rdfs:label>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#x"/>

<swrl:Variable rdf:about="urn:swrl#y"/>

<swrl:Variable rdf:about="urn:swrl#z"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasParent"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#y"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasSibling"/>
              <swrl:argument1 rdf:resource="urn:swrl#y"/>
              <swrl:argument2 rdf:resource="urn:swrl#z"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasUncleOrAunt"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#z"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasParent"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#y"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasParent"/>
              <swrl:argument1 rdf:resource="urn:swrl#y"/>
              <swrl:argument2 rdf:resource="urn:swrl#z"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasGrandparent"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#z"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
