ex:Muscle a owl:Class ;
    rdfs:subClassOf ex:DomainEntity .

ex:TechniqueCue a owl:Class ;
    rdfs:subClassOf ex:DomainEntity .

ex:abducts a owl:ObjectProperty .

ex:adducts a owl:ObjectProperty .

