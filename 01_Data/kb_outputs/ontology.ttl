ex:confidence a owl:DatatypeProperty .

ex:decreases a owl:ObjectProperty .

ex:domainSimilarity a owl:DatatypeProperty .

ex:evidenceSentence a owl:DatatypeProperty .

ex:extends a owl:ObjectProperty .

ex:flexes a owl:ObjectProperty .

ex:hasObject a owl:ObjectProperty .

ex:hasPredicate a owl:ObjectProperty .

ex:hasSubject a owl:ObjectProperty .

ex:increases a owl:ObjectProperty .

ex:influences a owl:ObjectProperty .

ex:involves a owl:ObjectProperty .

ex:originalObject a owl:DatatypeProperty .

ex:originalPredicate a owl:DatatypeProperty .

ex:originalSubject a owl:DatatypeProperty .

ex:produces a owl:ObjectProperty .

ex:reduces a owl:ObjectProperty .

ex:relatedTo a owl:ObjectProperty .

