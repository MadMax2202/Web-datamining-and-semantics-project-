@prefix ex: <http://example.org/benchpress-kg/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:BiomechanicalConcept a owl:Class ;
    rdfs:subClassOf ex:DomainEntity .

